generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMethod {
  dinheiro
  emola
  mpesa
  transferencia
}

enum ExpenseCategory {
  transporte
  embalagem
  materia_prima
  estoque
  outros
}

enum CashMovementType {
  entrada
  saida
  ajuste
  venda
}

model Product {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  brand     String?
  cost      Decimal  @db.Decimal(12, 2)
  price     Decimal  @db.Decimal(12, 2)
  stock     Int      @default(0)
  createdAt DateTime @default(now())

  stockEntries StockEntry[]
  saleItems    SaleItem[]
}

model StockEntry {
  id            String   @id @default(cuid())
  batchId       String
  productId     String
  quantity      Int
  expenseAmount Decimal? @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
}

model Sale {
  id            String   @id @default(cuid())
  customerName  String
  customerPhone String
  total         Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  items     SaleItem[]
  payments  SalePayment[]
  movements CashMovement[]
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String
  productId   String
  productName String
  productCode String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  unitCost    Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model SalePayment {
  id        String        @id @default(cuid())
  saleId    String
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod
  note      String?
  createdAt DateTime      @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model Expense {
  id           String          @id @default(cuid())
  description  String
  amount       Decimal         @db.Decimal(12, 2)
  category     ExpenseCategory
  date         DateTime
  stockBatchId String?
  createdAt    DateTime        @default(now())
}

model CashMovement {
  id           String           @id @default(cuid())
  type         CashMovementType
  amount       Decimal          @db.Decimal(12, 2)
  balanceAfter Decimal          @db.Decimal(12, 2)
  note         String?
  saleId       String?
  createdAt    DateTime         @default(now())

  sale Sale? @relation(fields: [saleId], references: [id])
}

// ponytail: single-row counter until multi-tenant matters
model AppMeta {
  id                Int     @id @default(1)
  productCounter    Int     @default(0)
  cashBalance       Decimal @default(0) @db.Decimal(12, 2)
  adminName         String?
  adminPasswordHash String?
}
